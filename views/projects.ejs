<%- include('partials/header') %>

<main class="container mx-auto px-5 max-w-[1600px] pb-24">
    <% projects.forEach((p, index) => { 
        const isEven = (index % 2 === 0); 
    %>
    <div class="pt-32 md:pt-48" id="<%= p.id %>">
        <!-- Titel & Icon Sektion -->
        <div class="text-center mb-12">
            <img class="animate-on-scroll section-img mx-auto mb-6" src="/<%= p.img %>" alt="<%= lang[p.img_alt] %>">
            <h1 class="animate-on-scroll text-4xl md:text-6xl font-black mb-4 tracking-tighter" style="--text-color: <%= p.text_color %>; color: var(--text-color);">
                <%= p.name %>
            </h1>
        </div>

        <!-- Projekt Row: Wechselnde Richtung durch flex-row / flex-row-reverse -->
        <section class="grid items-center gap-12 <%= isEven ? '' : 'reverse' %>">
            
            <!-- Slideshow Teil -->
            <div class="project-preview animate-on-scroll <%= isEven ? 'from-left' : 'from-right' %>">
                <div class="project-slider relative group overflow-hidden rounded-[2rem] shadow-2xl border border-[var(--shadow)] bg-[var(--card-bg)]/10" id="slider-<%= p.id %>">
                    
                    <% p.slides.forEach((slide, pIndex) => { %>
                        <div class="slide absolute inset-0 transition-opacity duration-1000 <%= (pIndex === 0) ? 'active' : '' %>">
                            <!-- WICHTIG: Die {{lang}} Ersetzung für SEO-Bilder falls nötig -->
                            <img src="/<%= slide.replace('{{lang}}', currentLang) %>" 
                                 class="w-full h-full object-cover" 
                                 alt="<%= p.img_alt %>" title="<%= p.img_title %>" loading="lazy">
                        </div>
                    <% }) %>

                    <!-- Navigations-Pfeile (Nur bei Hover sichtbar) -->
                    <div class="slider-nav justify-between items-center px-4 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">
                        <button class="w-12 h-12 flex items-center justify-center bg-black/40 text-white rounded-full backdrop-blur-md pointer-events-auto hover:bg-[var(--accent-blue)] transition-all" 
                                onclick="moveSlide('<%= p.id %>', -1)">❮</button>
                        <button class="w-12 h-12 flex items-center justify-center bg-black/40 text-white rounded-full backdrop-blur-md pointer-events-auto hover:bg-[var(--accent-blue)] transition-all" 
                                onclick="moveSlide('<%= p.id %>', 1)">❯</button>
                    </div>

                    <!-- Dots -->
                    <div class="slider-dots absolute bottom-6 w-full flex justify-center gap-3 z-20">
                        <% p.slides.forEach((_, pIndex) => { %>
                            <span class="dot <%= (pIndex === 0) ? 'active' : '' %> w-3 h-3 rounded-full cursor-pointer transition-all duration-300" 
                                   data-index="<%= pIndex %>" onclick="setSlide('<%= p.id %>', this.dataset.index)"></span>
                        <% }) %>
                    </div>
                </div>
            </div>
            
            <!-- Text Teil -->
            <div class="animate-on-scroll <%= isEven ? 'from-right' : 'from-left' %> justify-center">
                <h3 class="text-2xl font-bold text-[var(--text-main)] mb-6">
                    <%= lang[p.intro_key] %>
                </h3>
                <p class="text-lg leading-relaxed text-[var(--text-dim)] text-justify mb-8">
                    <%= lang[p.desc_key] %>
                </p>
                <div class="border-l-4 border-[var(--accent-blue)] pl-6 py-2 mb-10">
                    <strong class="text-xl italic text-[var(--text-main)]">
                        <%= lang[p.slogan_key] %>
                    </strong>
                </div>
                
                <div>
                    <a href="<%= p.url %>" target="_blank" class="inline-block px-10 py-5 bg-[var(--btn-primary)] hover:bg-sky-600 text-[var(--text-main)] font-extrabold rounded-2xl transition-all hover:scale-105 shadow-xl hover:shadow-[#38bdf8]/20">
                        <%= lang.btn_visit %>
                    </a>
                </div>
            </div>
        </section>
    </div>
    <% }) %>
</main>

<%- include('partials/footer') %>
