<body class="">
<script>
    (function() {
        const hour = new Date().getHours();
        const savedTheme = localStorage.getItem('theme');
        const body = document.body;
        
        // Logik: gespeichertes Theme ODER (kein Speicher UND Nachtzeit)
        const isDark = savedTheme === 'dark' || (!savedTheme && (hour >= 18 || hour < 6));
        if (isDark) {
            body.classList.add('dark-mode');
        }
    })();
</script>
<header class="border-[#38bdf8]/10 px-5">
