    <link rel="canonical" href="<%= cleanUrl %>">
    <link rel="alternate" hreflang="de" href="<%= cleanUrl %>?lang=de" />
    <link rel="alternate" hreflang="en" href="<%= cleanUrl %>?lang=en" />
